#!/bin/bash

# gemini-timeout - Enhanced Gemini CLI with timeout support
# Default timeout: 180 seconds (3 minutes)

set -e

# Default values
DEFAULT_TIMEOUT=180
TIMEOUT=$DEFAULT_TIMEOUT
MODEL=""
OUTPUT_FORMAT=""
PROMPT=""
VERBOSE=false

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print usage
usage() {
    cat << EOF
Usage: $0 [OPTIONS] "PROMPT"

Enhanced Gemini CLI with timeout support.

Options:
  -t, --timeout SECONDS   Timeout in seconds (default: 180)
  -m, --model MODEL       Specify Gemini model (e.g., gemini-1.5-pro)
  -o, --output-format FMT Output format (e.g., json)
  -v, --verbose           Show verbose output
  -h, --help              Show this help message

Examples:
  $0 "Explain quantum computing"
  $0 --timeout 120 "Analyze this code"
  $0 --model gemini-1.5-pro --output-format json "Return data as JSON"

Default timeout: 180 seconds (3 minutes)
EOF
}

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -t|--timeout)
            TIMEOUT="$2"
            shift 2
            ;;
        -m|--model)
            MODEL="$2"
            shift 2
            ;;
        -o|--output-format)
            OUTPUT_FORMAT="$2"
            shift 2
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo -e "${RED}Error: Unknown option $1${NC}" >&2
            usage
            exit 1
            ;;
        *)
            PROMPT="$1"
            shift
            ;;
    esac
done

# Check if prompt is provided
if [ -z "$PROMPT" ]; then
    echo -e "${RED}Error: No prompt provided${NC}" >&2
    usage
    exit 1
fi

# Check if gemini is installed
if ! command -v gemini &> /dev/null; then
    echo -e "${RED}Error: gemini CLI is not installed${NC}" >&2
    echo "Install with: brew install gemini-cli"
    exit 1
fi

# Check if timeout is available
if ! command -v timeout &> /dev/null; then
    echo -e "${YELLOW}Warning: timeout command not found, using fallback method${NC}" >&2
    HAS_TIMEOUT=false
else
    HAS_TIMEOUT=true
fi

# Build gemini command
GEMINI_CMD="gemini"
if [ -n "$MODEL" ]; then
    GEMINI_CMD="$GEMINI_CMD --model $MODEL"
fi
if [ -n "$OUTPUT_FORMAT" ]; then
    GEMINI_CMD="$GEMINI_CMD --output-format $OUTPUT_FORMAT"
fi
GEMINI_CMD="$GEMINI_CMD --prompt \"$PROMPT\""

# Print verbose info
if [ "$VERBOSE" = true ]; then
    echo -e "${BLUE}🔧 Gemini Timeout Wrapper${NC}"
    echo -e "  Prompt: $PROMPT"
    echo -e "  Timeout: ${TIMEOUT}s"
    echo -e "  Model: ${MODEL:-default}"
    echo -e "  Output format: ${OUTPUT_FORMAT:-default}"
    echo -e "  Command: $GEMINI_CMD"
    echo ""
fi

echo -e "${YELLOW}⏱️  Running Gemini with ${TIMEOUT}s timeout...${NC}"

# Run with timeout
if [ "$HAS_TIMEOUT" = true ]; then
    # Method 1: Use timeout command
    if [ "$VERBOSE" = true ]; then
        echo -e "${BLUE}Using timeout command${NC}"
    fi
    
    # Execute with timeout
    eval "timeout $TIMEOUT $GEMINI_CMD"
    EXIT_CODE=$?
    
    if [ $EXIT_CODE -eq 124 ]; then
        echo -e "\n${RED}❌ Timeout after ${TIMEOUT} seconds${NC}" >&2
        exit 124
    elif [ $EXIT_CODE -ne 0 ]; then
        echo -e "\n${RED}❌ Gemini failed with exit code $EXIT_CODE${NC}" >&2
        exit $EXIT_CODE
    fi
else
    # Method 2: Manual timeout (fallback)
    if [ "$VERBOSE" = true ]; then
        echo -e "${BLUE}Using manual timeout fallback${NC}"
    fi
    
    # Start gemini in background
    eval "$GEMINI_CMD" &
    PID=$!
    
    # Wait for timeout or completion
    for i in $(seq 1 $TIMEOUT); do
        # Check if process is still running
        if ! kill -0 $PID 2>/dev/null; then
            # Process finished
            wait $PID
            EXIT_CODE=$?
            
            if [ $EXIT_CODE -eq 0 ]; then
                if [ "$VERBOSE" = true ]; then
                    echo -e "\n${GREEN}✅ Completed in ${i}s${NC}"
                fi
                exit 0
            else
                echo -e "\n${RED}❌ Failed with exit code $EXIT_CODE${NC}" >&2
                exit $EXIT_CODE
            fi
        fi
        
        # Show progress every 10 seconds
        if [ $((i % 10)) -eq 0 ] && [ "$VERBOSE" = true ]; then
            echo -ne "${BLUE}.${NC}"
        fi
        
        sleep 1
    done
    
    # Timeout reached
    kill -9 $PID 2>/dev/null
    echo -e "\n${RED}❌ Timeout after ${TIMEOUT} seconds${NC}" >&2
    exit 124
fi

if [ "$VERBOSE" = true ]; then
    echo -e "\n${GREEN}✅ Completed successfully${NC}"
fi